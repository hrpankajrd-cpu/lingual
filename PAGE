<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LinguaHire Academy – Turning Languages into Careers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --blue: #1A4DB5;
    --blue-dark: #0f2f75;
    --blue-light: #2563eb;
    --orange: #F5A623;
    --red: #D0021B;
    --green: #2ECC40;
    --gold: #f0c040;
    --white: #ffffff;
    --off-white: #f8f7f3;
    --text: #1a1a2e;
    --text-muted: #5a5a7a;
    --font-display: 'Playfair Display', serif;
    --font-body: 'Sora', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: var(--white);
    overflow-x: hidden;
  }

  /* ========== NAVBAR ========== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(26, 77, 181, 0.97);
    backdrop-filter: blur(10px);
    padding: 0 5%;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
    box-shadow: 0 2px 24px rgba(26,77,181,0.25);
  }

  .nav-logo {
    display: flex; align-items: center; gap: 10px; text-decoration: none;
  }
  .nav-logo-icon {
    width: 44px; height: 44px;
    background: var(--orange);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    box-shadow: 0 2px 8px rgba(245,166,35,0.4);
  }
  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--white);
    line-height: 1.1;
  }
  .nav-logo-text span {
    color: var(--orange);
  }

  .nav-links {
    display: flex; align-items: center; gap: 28px;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--orange); }

  .btn-enroll-nav {
    background: var(--orange);
    color: var(--white) !important;
    padding: 9px 20px;
    border-radius: 25px;
    font-weight: 700 !important;
    font-size: 0.85rem !important;
    letter-spacing: 0.03em;
    box-shadow: 0 3px 12px rgba(245,166,35,0.4);
    transition: transform 0.2s, box-shadow 0.2s !important;
  }
  .btn-enroll-nav:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(245,166,35,0.5);
  }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span { width: 24px; height: 2px; background: white; border-radius: 2px; }

  /* ========== HERO ========== */
  .hero {
    min-height: 100vh;
    background: linear-gradient(135deg, #0a1e5e 0%, #1A4DB5 45%, #1e3a8a 70%, #0f2060 100%);
    position: relative;
    display: flex; align-items: center;
    overflow: hidden;
    padding-top: 68px;
  }

  /* Animated globe rings */
  .hero-globe {
    position: absolute; right: -80px; top: 50%; transform: translateY(-50%);
    width: 600px; height: 600px;
    opacity: 0.07;
    pointer-events: none;
  }
  .globe-ring {
    position: absolute; border-radius: 50%; border: 1px solid white;
    top: 50%; left: 50%; transform: translate(-50%,-50%);
  }

  .hero-pattern {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle at 20% 80%, rgba(245,166,35,0.08) 0%, transparent 50%),
                      radial-gradient(circle at 80% 20%, rgba(46,204,64,0.06) 0%, transparent 40%),
                      radial-gradient(circle at 50% 50%, rgba(26,77,181,0) 0%, rgba(0,0,30,0.3) 100%);
    pointer-events: none;
  }

  /* Floating grid dots */
  .hero-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 700px;
    padding: 60px 8%;
  }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(245,166,35,0.15);
    border: 1px solid rgba(245,166,35,0.4);
    color: var(--orange);
    padding: 7px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .hero-title .accent { color: var(--orange); }
  .hero-title .line2 {
    display: block;
    color: rgba(255,255,255,0.9);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 700;
    margin-top: 6px;
  }

  .hero-sub {
    color: rgba(255,255,255,0.7);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 22px 0 36px;
    max-width: 520px;
  }

  .hero-btns {
    display: flex; flex-wrap: wrap; gap: 14px;
  }

  .btn-primary {
    background: var(--orange);
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 6px 24px rgba(245,166,35,0.45);
    transition: transform 0.2s, box-shadow 0.2s;
    letter-spacing: 0.02em;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(245,166,35,0.55); }

  .btn-outline {
    background: transparent;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1.5px solid rgba(255,255,255,0.4);
    display: inline-flex; align-items: center; gap: 8px;
    transition: background 0.2s, border-color 0.2s;
  }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); }

  .hero-stats {
    display: flex; gap: 36px; margin-top: 50px;
    flex-wrap: wrap;
  }
  .stat {
    display: flex; flex-direction: column;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2rem; font-weight: 900;
    color: var(--orange);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
    margin-top: 4px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ========== SPEECH BUBBLES ========== */
  .bubbles-container {
    position: absolute; inset: 0; pointer-events: none; z-index: 3;
  }
  .bubble {
    position: absolute;
    background: var(--white);
    border-radius: 20px;
    padding: 10px 18px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--blue);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
    animation: floatBubble linear infinite;
    white-space: nowrap;
    border: 2px solid rgba(26,77,181,0.1);
  }
  .bubble::after {
    content: '';
    position: absolute;
    bottom: -10px; left: 20px;
    border: 6px solid transparent;
    border-top-color: var(--white);
  }

  @keyframes floatBubble {
    0%   { transform: translateY(0) rotate(-2deg); opacity: 0; }
    10%  { opacity: 1; }
    50%  { transform: translateY(-20px) rotate(2deg); }
    90%  { opacity: 1; }
    100% { transform: translateY(-40px) rotate(-1deg); opacity: 0; }
  }

  .bubble:nth-child(1) { right: 55%; top: 18%; animation-duration: 6s; animation-delay: 0s; background: #fff3e0; color: #c85800; border-color: #f5a623; }
  .bubble:nth-child(2) { right: 38%; top: 28%; animation-duration: 7.5s; animation-delay: 1.2s; background: #e8f0fe; color: #1A4DB5; }
  .bubble:nth-child(3) { right: 60%; top: 50%; animation-duration: 5.5s; animation-delay: 2.5s; background: #e6f9ea; color: #1a7a28; border-color: #2ECC40; }
  .bubble:nth-child(4) { right: 30%; top: 60%; animation-duration: 8s; animation-delay: 0.7s; }
  .bubble:nth-child(5) { right: 48%; top: 72%; animation-duration: 6.5s; animation-delay: 3.2s; background: #fff0f0; color: #a00015; border-color: #D0021B; }
  .bubble:nth-child(6) { right: 25%; top: 40%; animation-duration: 7s; animation-delay: 1.8s; background: #f3e5ff; color: #6b21a8; }

  /* ========== SECTION STYLES ========== */
  section { padding: 90px 8%; }

  .section-label {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }
  .section-label::before {
    content: '';
    width: 24px; height: 3px;
    background: var(--orange);
    border-radius: 2px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 16px;
  }
  .section-title .highlight { color: var(--blue); }
  .section-title .orange { color: var(--orange); }

  .section-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 560px;
  }

  /* World divider */
  .world-divider {
    text-align: center;
    padding: 20px 0;
    font-size: 1.5rem;
    letter-spacing: 12px;
    color: rgba(26,77,181,0.12);
    overflow: hidden;
    user-select: none;
  }

  /* ========== ABOUT ========== */
  .about { background: var(--off-white); }

  .about-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 70px; align-items: center;
  }

  .about-visual {
    position: relative;
  }
  .about-img-box {
    width: 100%; aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-dark) 100%);
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    font-size: 8rem;
    box-shadow: 20px 20px 60px rgba(26,77,181,0.25);
    overflow: hidden;
    position: relative;
  }
  .about-img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(26,77,181,0.8), rgba(245,166,35,0.3));
    border-radius: 24px;
  }
  .about-img-text {
    position: relative; z-index: 1;
    font-size: 5rem;
  }

  .trust-badges {
    display: flex; gap: 16px; flex-wrap: wrap; margin-top: 28px;
  }
  .badge {
    background: var(--white);
    border-radius: 14px;
    padding: 14px 20px;
    display: flex; flex-direction: column; align-items: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    min-width: 100px;
    border-top: 3px solid var(--blue);
    transition: transform 0.2s;
  }
  .badge:hover { transform: translateY(-3px); }
  .badge:nth-child(2) { border-top-color: var(--orange); }
  .badge:nth-child(3) { border-top-color: var(--green); }
  .badge:nth-child(4) { border-top-color: var(--red); }
  .badge-num {
    font-family: var(--font-display);
    font-size: 1.6rem; font-weight: 900;
    color: var(--blue);
    line-height: 1;
  }
  .badge-num.orange { color: var(--orange); }
  .badge-num.green { color: var(--green); }
  .badge-num.red { color: var(--red); }
  .badge-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 4px; text-align: center; font-weight: 500; }

  .stars {
    color: var(--gold);
    font-size: 0.9rem;
    margin-top: 4px;
    letter-spacing: 1px;
  }

  /* ========== LANGUAGES ========== */
  .languages { background: var(--white); }

  .lang-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 18px;
    margin-top: 50px;
  }

  .lang-card {
    background: var(--white);
    border: 1.5px solid #e8eaf0;
    border-radius: 20px;
    padding: 24px 16px;
    text-align: center;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    position: relative;
    overflow: hidden;
  }
  .lang-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s;
  }
  .lang-card:hover::before { transform: scaleX(1); }
  .lang-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(26,77,181,0.14);
    border-color: rgba(26,77,181,0.2);
  }
  .lang-flag { font-size: 2.8rem; margin-bottom: 10px; }
  .lang-name {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }
  .lang-tags {
    display: flex; flex-wrap: wrap; gap: 5px; justify-content: center;
  }
  .tag {
    font-size: 0.65rem; font-weight: 600;
    padding: 3px 9px;
    border-radius: 10px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .tag-beg { background: #e8f5e9; color: #2e7d32; }
  .tag-adv { background: #fff3e0; color: #e65100; }
  .tag-biz { background: #e3f2fd; color: #1565c0; }
  .tag-kids { background: #f3e5f5; color: #6a1b9a; }
  .tag-exam { background: #fce4ec; color: #880e4f; }

  /* ========== WHY CHOOSE US ========== */
  .why { background: linear-gradient(135deg, #0a1e5e 0%, #1A4DB5 100%); color: white; position: relative; overflow: hidden; }
  .why .section-label { color: var(--orange); }
  .why .section-label::before { background: var(--orange); }
  .why .section-title { color: white; }
  .why .section-desc { color: rgba(255,255,255,0.7); }

  .why-pattern {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
    pointer-events: none;
  }

  .why-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px; margin-top: 50px; position: relative;
  }

  .why-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 30px 24px;
    transition: background 0.3s, transform 0.3s;
    backdrop-filter: blur(4px);
  }
  .why-card:hover {
    background: rgba(255,255,255,0.12);
    transform: translateY(-4px);
  }
  .why-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 18px;
  }
  .icon-blue { background: rgba(37,99,235,0.4); }
  .icon-orange { background: rgba(245,166,35,0.3); }
  .icon-green { background: rgba(46,204,64,0.25); }
  .icon-red { background: rgba(208,2,27,0.3); }
  .icon-purple { background: rgba(139,92,246,0.3); }

  .why-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: white;
    margin-bottom: 8px;
  }
  .why-card p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
  }

  /* ========== COURSES ========== */
  .courses { background: var(--off-white); }

  .courses-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px; margin-top: 50px;
  }

  .course-card {
    background: var(--white);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: transform 0.25s, box-shadow 0.25s;
    border: 1px solid #eee;
  }
  .course-card:hover { transform: translateY(-5px); box-shadow: 0 16px 50px rgba(0,0,0,0.1); }

  .course-header {
    padding: 28px 24px 20px;
    position: relative;
  }
  .course-header-blue { background: linear-gradient(135deg, #1A4DB5, #2563eb); }
  .course-header-orange { background: linear-gradient(135deg, #f5a623, #e8840a); }
  .course-header-green { background: linear-gradient(135deg, #2ECC40, #1a9e2e); }
  .course-header-red { background: linear-gradient(135deg, #D0021B, #a00015); }
  .course-header-purple { background: linear-gradient(135deg, #7c3aed, #5b21b6); }

  .course-emoji { font-size: 2.5rem; }
  .course-title {
    font-family: var(--font-display);
    font-size: 1.2rem; font-weight: 900;
    color: white; margin-top: 10px;
  }
  .course-body { padding: 20px 24px; }
  .course-desc { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 16px; }
  .course-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
  .course-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.85rem; font-weight: 700;
    color: var(--blue); text-decoration: none;
    padding: 8px 0;
    transition: gap 0.2s;
  }
  .course-cta:hover { gap: 10px; }

  /* ========== TESTIMONIALS ========== */
  .testimonials { background: var(--white); }

  .testi-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px; margin-top: 50px;
  }

  .testi-card {
    background: var(--off-white);
    border-radius: 22px;
    padding: 28px;
    border-left: 4px solid var(--blue);
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .testi-card:nth-child(2) { border-left-color: var(--orange); }
  .testi-card:nth-child(3) { border-left-color: var(--green); }
  .testi-card:hover { transform: translateY(-3px); box-shadow: 0 10px 35px rgba(0,0,0,0.08); }

  .quote-mark {
    font-size: 4rem; line-height: 0.6;
    color: var(--blue); opacity: 0.15;
    font-family: Georgia, serif;
    margin-bottom: 14px;
  }
  .testi-card:nth-child(2) .quote-mark { color: var(--orange); }
  .testi-card:nth-child(3) .quote-mark { color: var(--green); }

  .testi-text {
    font-size: 0.93rem;
    line-height: 1.75;
    color: var(--text);
    font-style: italic;
    margin-bottom: 22px;
  }
  .testi-author {
    display: flex; align-items: center; gap: 14px;
  }
  .testi-avatar {
    width: 46px; height: 46px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    background: linear-gradient(135deg, var(--blue), var(--blue-dark));
    flex-shrink: 0;
  }
  .testi-info .name { font-weight: 700; font-size: 0.9rem; }
  .testi-info .detail { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }
  .testi-outcome {
    display: inline-block;
    background: #e3f2fd; color: #1565c0;
    font-size: 0.72rem; font-weight: 700;
    padding: 3px 10px; border-radius: 10px;
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .testi-card:nth-child(2) .testi-outcome { background: #fff3e0; color: #e65100; }
  .testi-card:nth-child(3) .testi-outcome { background: #e8f5e9; color: #2e7d32; }

  /* ========== GALLERY ========== */
  .gallery { background: var(--text); padding: 70px 8%; }
  .gallery .section-label { color: var(--orange); }
  .gallery .section-label::before { background: var(--orange); }
  .gallery .section-title { color: white; }

  .gallery-strip {
    display: grid; grid-template-columns: 2fr 1fr 1fr;
    gap: 16px; margin-top: 40px;
  }
  .gallery-item {
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #1A4DB5, #0f2060);
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
    position: relative;
    transition: transform 0.3s;
  }
  .gallery-item:first-child { aspect-ratio: unset; grid-row: span 2; font-size: 6rem; }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,30,0.3);
    display: flex; align-items: flex-end;
    padding: 16px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-item-overlay { opacity: 1; }
  .gallery-item-label {
    color: white; font-size: 0.85rem; font-weight: 600;
    background: rgba(0,0,0,0.5); padding: 5px 12px; border-radius: 8px;
  }
  .g1 { background: linear-gradient(135deg, #1A4DB5 0%, #0f2060 100%); }
